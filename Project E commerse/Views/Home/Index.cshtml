@{
    ViewData["Title"] = "Online Shopping – ShopZone Egypt";
}

<style>
    .hero-banner {
        background: linear-gradient(135deg, #131921 0%, #232f3e 50%, #37475a 100%);
        color: #fff;
        padding: 50px 40px;
        border-radius: 8px;
        position: relative;
        overflow: hidden;
        margin-bottom: 20px;
    }

        .hero-banner::before {
            content: '';
            position: absolute;
            right: -50px;
            top: -50px;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(254,189,105,0.2) 0%, transparent 70%);
            border-radius: 50%;
        }

    .deal-card {
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        padding: 14px;
        transition: box-shadow .2s, transform .2s;
    }

        .deal-card:hover {
            box-shadow: 0 4px 16px rgba(0,0,0,.12);
            transform: translateY(-2px);
        }

    .section-title {
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .section-title a {
            font-size: .8rem;
            color: #007185;
            text-decoration: none;
            font-weight: 400;
        }

            .section-title a:hover {
                text-decoration: underline;
                color: #c7511f;
            }

    .cat-pill {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        padding: 14px 10px;
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 8px;
        text-decoration: none;
        color: var(--text-primary);
        font-size: .78rem;
        font-weight: 600;
        text-align: center;
        transition: all .2s;
    }

        .cat-pill:hover {
            border-color: var(--amazon-orange);
            background: #fffbf5;
            transform: translateY(-2px);
            color: var(--text-primary);
        }

        .cat-pill i {
            font-size: 1.8rem;
        }
</style>

<div class="page-wrap">

    <!-- ═══ HERO BANNER ════════════════════════════════════════ -->
    <div class="hero-banner">
        <div style="max-width:600px; position:relative; z-index:1;">
            <div style="color:var(--amazon-orange); font-size:.8rem; font-weight:700; text-transform:uppercase; letter-spacing:.1em; margin-bottom:8px;">
                🔥 Today's Deals
            </div>
            <h1 style="font-size:2.2rem; font-weight:900; line-height:1.2; margin-bottom:12px;">
                Shop Everything<br />
                <span style="color:var(--amazon-orange);">You Love</span>
            </h1>
            <p style="opacity:.8; font-size:.95rem; margin-bottom:20px;">
                Millions of products. FREE delivery on eligible orders. Shop now and save big!
            </p>
            <a asp-controller="Category" asp-action="Index"
               style="display:inline-block; background:var(--amazon-yellow); color:var(--amazon-dark); padding:12px 28px; border-radius:24px; font-weight:700; font-size:.95rem; text-decoration:none; transition:background .2s;">
                Start Shopping →
            </a>
        </div>
    </div>

    <!-- ═══ FEATURED BANNERS (3-col) ════════════════════════════ -->
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-bottom:20px;">
        <div style="background:linear-gradient(135deg,#febd69,#f90); padding:20px; border-radius:8px; color:var(--amazon-dark);">
            <div style="font-size:.7rem; font-weight:700; text-transform:uppercase; margin-bottom:4px;">New Arrivals</div>
            <div style="font-size:1.1rem; font-weight:900;">Latest Tech 2024</div>
            <a asp-controller="Category" asp-action="Index" asp-route-sort="newest"
               style="display:inline-block; margin-top:10px; font-size:.78rem; color:var(--amazon-dark); text-decoration:underline;">Shop now</a>
        </div>
        <div style="background:linear-gradient(135deg,#232f3e,#131921); padding:20px; border-radius:8px; color:#fff;">
            <div style="font-size:.7rem; font-weight:700; text-transform:uppercase; margin-bottom:4px; color:var(--amazon-orange);">Best Sellers</div>
            <div style="font-size:1.1rem; font-weight:900;">Top Rated Items</div>
            <a asp-controller="Category" asp-action="Index"
               style="display:inline-block; margin-top:10px; font-size:.78rem; color:var(--amazon-orange); text-decoration:underline;">Shop now</a>
        </div>
        <div style="background:linear-gradient(135deg,#067d62,#04503e); padding:20px; border-radius:8px; color:#fff;">
            <div style="font-size:.7rem; font-weight:700; text-transform:uppercase; margin-bottom:4px; color:#7fffca;">FREE Delivery</div>
            <div style="font-size:1.1rem; font-weight:900;">On All Orders</div>
            <a asp-controller="Category" asp-action="Index"
               style="display:inline-block; margin-top:10px; font-size:.78rem; color:#7fffca; text-decoration:underline;">Shop now</a>
        </div>
    </div>

    <!-- ═══ SHOP BY CATEGORY ═════════════════════════════════════ -->
    <div style="background:#fff; border:1px solid #e5e5e5; border-radius:6px; padding:16px 20px; margin-bottom:20px;">
        <div class="section-title">
            Shop by Category
            <a asp-controller="Category" asp-action="Index">See all categories ›</a>
        </div>
        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(90px,1fr)); gap:10px;">
            <a asp-controller="Category" asp-action="Index" class="cat-pill">
                <i class="bi bi-phone" style="color:#e47911;"></i>Electronics
            </a>
            <a asp-controller="Category" asp-action="Index" class="cat-pill">
                <i class="bi bi-bag" style="color:#067d62;"></i>Fashion
            </a>
            <a asp-controller="Category" asp-action="Index" class="cat-pill">
                <i class="bi bi-house" style="color:#37475a;"></i>Home
            </a>
            <a asp-controller="Category" asp-action="Index" class="cat-pill">
                <i class="bi bi-controller" style="color:#b12704;"></i>Gaming
            </a>
            <a asp-controller="Category" asp-action="Index" class="cat-pill">
                <i class="bi bi-book" style="color:#007185;"></i>Books
            </a>
            <a asp-controller="Category" asp-action="Index" class="cat-pill">
                <i class="bi bi-bicycle" style="color:#c60;"></i>Sports
            </a>
            <a asp-controller="Category" asp-action="Index" class="cat-pill">
                <i class="bi bi-flower1" style="color:#c74b50;"></i>Beauty
            </a>
            <a asp-controller="Category" asp-action="Index" class="cat-pill">
                <i class="bi bi-tools" style="color:#555;"></i>Tools
            </a>
        </div>
    </div>

    <!-- ═══ WHY SHOPZONE ══════════════════════════════════════════ -->
    <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:20px;">
        @foreach (var (icon, title, desc) in new[]{
                ("bi-truck","FREE Delivery","On all eligible orders"),
                ("bi-shield-check","Buyer Protection","100% secure shopping"),
                ("bi-arrow-return-left","Easy Returns","30-day hassle-free returns"),
                ("bi-headset","24/7 Support","We're always here to help")
                })
        {
            <div style="background:#fff; border:1px solid #e5e5e5; border-radius:6px; padding:14px; text-align:center;">
                <i class="bi @icon" style="font-size:1.8rem; color:var(--amazon-orange);"></i>
                <div style="font-weight:700; font-size:.85rem; margin:6px 0 2px;">@title</div>
                <div style="font-size:.75rem; color:var(--text-secondary);">@desc</div>
            </div>
        }
    </div>

</div>
