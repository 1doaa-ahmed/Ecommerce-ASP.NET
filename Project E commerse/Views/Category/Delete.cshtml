@model Project_E_commerse.Models.Category

@{
    ViewData["Title"] = "Delete Category";
}

<div class="page-wrap">

    <!-- Breadcrumb -->
    <div class="breadcrumb-bar">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span>›</span>
        <a asp-area="Admin" asp-controller="Products" asp-action="Index">Admin</a>
        <span>›</span>
        <a asp-controller="Category" asp-action="Index">Categories</a>
        <span>›</span>
        Delete
    </div>

    <div style="max-width:520px; margin:0 auto;">

        <div style="background:#fff; border:1px solid #f5c6cb; border-radius:8px; padding:32px; text-align:center;">

            <!-- Warning Icon -->
            <div style="width:72px; height:72px; background:#fff0f0; border-radius:50%;
                        display:flex; align-items:center; justify-content:center; margin:0 auto 20px;">
                <i class="bi bi-exclamation-triangle-fill" style="font-size:2rem; color:#b12704;"></i>
            </div>

            <h2 style="font-size:1.3rem; font-weight:700; color:var(--text-primary); margin-bottom:8px;">
                Delete Category?
            </h2>

            <p style="font-size:.88rem; color:var(--text-secondary); margin-bottom:24px; line-height:1.6;">
                Are you sure you want to delete this category?
                <br />This action <strong style="color:#b12704;">cannot be undone</strong> and may affect products linked to it.
            </p>

            <!-- Category Info Card -->
            <div style="background:#f7f7f7; border:1px solid #e5e5e5; border-radius:6px;
                        padding:16px; margin-bottom:28px; text-align:left;">

                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
                    <span style="font-size:.78rem; color:var(--text-secondary);">Category ID</span>
                    <span style="font-weight:700; font-size:.88rem;">#@Model.CategoryId</span>
                </div>

                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
                    <span style="font-size:.78rem; color:var(--text-secondary);">Name</span>
                    <span style="font-weight:700; font-size:.88rem;">@Model.Name</span>
                </div>

                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <span style="font-size:.78rem; color:var(--text-secondary);">Parent Category</span>
                    <span style="font-weight:700; font-size:.88rem;">
                        @(Model.ParentCategory?.Name ?? "— Top Level —")
                    </span>
                </div>

                @if (Model.Products.Any())
                {
                    <div style="margin-top:12px; padding-top:12px; border-top:1px solid #e5e5e5;">
                        <span style="font-size:.78rem; color:#b12704; font-weight:700;">
                            <i class="bi bi-exclamation-circle-fill me-1"></i>
                            Warning: This category has @Model.Products.Count linked product(s)
                        </span>
                    </div>
                }
            </div>

            <!-- Actions -->
            <form asp-action="Delete" method="post" style="display:flex; gap:12px;">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="CategoryId" />

                <button type="submit"
                        style="flex:1; background:#b12704; color:#fff; border:none; border-radius:4px;
                               padding:10px 0; font-size:.95rem; font-weight:700; cursor:pointer;
                               font-family:'Cairo',sans-serif; transition:background .2s;"
                        onmouseover="this.style.background='#8e1f03'"
                        onmouseout="this.style.background='#b12704'">
                    <i class="bi bi-trash3-fill me-1"></i> Yes, Delete
                </button>

                <a asp-controller="Category" asp-action="Index"
                   class="btn-secondary-shop"
                   style="flex:1; text-align:center; border-radius:4px; padding:10px 0; font-size:.95rem;">
                    <i class="bi bi-arrow-left me-1"></i> Cancel
                </a>
            </form>

        </div>
    </div>

</div>
