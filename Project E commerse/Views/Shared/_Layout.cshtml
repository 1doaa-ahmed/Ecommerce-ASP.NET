<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – ShopZone</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <style>
        :root {
            --amazon-dark: #131921;
            --amazon-mid: #232f3e;
            --amazon-orange: #febd69;
            --amazon-yellow: #f90;
            --amazon-light: #37475a;
            --noon-purple: #6b21a8;
            --text-primary: #0f1111;
            --text-secondary: #565959;
            --border: #ddd;
            --bg-light: #f3f3f3;
            --bg-white: #fff;
            --green: #067d62;
            --red: #b12704;
            --star: #f90;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background: var(--bg-light);
            color: var(--text-primary);
        }

        /* ── TOP NAV ─────────────────────────────────────── */
        .navbar-top {
            background: var(--amazon-dark);
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .nav-logo {
            color: #fff;
            font-weight: 900;
            font-size: 1.5rem;
            text-decoration: none;
            white-space: nowrap;
        }

            .nav-logo span {
                color: var(--amazon-orange);
            }

        .nav-search {
            flex: 1;
            display: flex;
            max-width: 700px;
        }

            .nav-search select {
                background: #f3f3f3;
                border: none;
                border-radius: 4px 0 0 4px;
                padding: 0 8px;
                font-size: .75rem;
                color: #555;
                cursor: pointer;
                border-right: 1px solid #cdcdcd;
                min-width: 60px;
            }

            .nav-search input {
                flex: 1;
                border: none;
                padding: 9px 12px;
                font-size: .9rem;
                outline: none;
                font-family: 'Cairo', sans-serif;
            }

            .nav-search button {
                background: var(--amazon-orange);
                border: none;
                padding: 0 14px;
                border-radius: 0 4px 4px 0;
                cursor: pointer;
                font-size: 1.1rem;
                transition: background .2s;
            }

                .nav-search button:hover {
                    background: var(--amazon-yellow);
                }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 4px;
            margin-left: auto;
        }

        .nav-btn {
            color: #fff;
            text-decoration: none;
            padding: 6px 10px;
            border-radius: 4px;
            font-size: .8rem;
            line-height: 1.3;
            border: 1px solid transparent;
            white-space: nowrap;
            cursor: pointer;
            background: none;
            transition: border-color .15s;
        }

            .nav-btn:hover {
                border-color: #fff;
                color: #fff;
            }

            .nav-btn small {
                display: block;
                font-size: .65rem;
                opacity: .8;
            }

            .nav-btn strong {
                display: block;
                font-size: .85rem;
            }

        .cart-btn {
            position: relative;
            font-size: 1.5rem;
            padding: 4px 10px;
        }

        .cart-count {
            position: absolute;
            top: 0;
            right: 4px;
            background: var(--amazon-orange);
            color: var(--amazon-dark);
            border-radius: 50%;
            font-size: .65rem;
            font-weight: 900;
            width: 18px;
            height: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* ── SUB NAV ─────────────────────────────────────── */
        .navbar-sub {
            background: var(--amazon-mid);
            display: flex;
            align-items: center;
            gap: 4px;
            padding: 4px 16px;
            overflow-x: auto;
        }

        .sub-link {
            color: #fff;
            text-decoration: none;
            padding: 6px 10px;
            font-size: .82rem;
            white-space: nowrap;
            border-radius: 3px;
            border: 1px solid transparent;
            transition: border-color .15s;
        }

            .sub-link:hover {
                border-color: #fff;
                color: #fff;
            }

            .sub-link.all {
                font-weight: 700;
                display: flex;
                align-items: center;
                gap: 5px;
            }

        /* ── ALERTS ──────────────────────────────────────── */
        .alert-bar {
            padding: 10px 20px;
            font-size: .88rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .alert-bar.success {
                background: #ddffdd;
                border-left: 4px solid #067d62;
                color: #067d62;
            }

            .alert-bar.danger {
                background: #fff0f0;
                border-left: 4px solid #b12704;
                color: #b12704;
            }

            .alert-bar .close-btn {
                margin-left: auto;
                background: none;
                border: none;
                cursor: pointer;
                font-size: 1.1rem;
            }

        /* ── MAIN ────────────────────────────────────────── */
        .page-wrap {
            max-width: 1400px;
            margin: 0 auto;
            padding: 16px;
        }

        /* ── FOOTER ──────────────────────────────────────── */
        .footer-back {
            background: var(--amazon-light);
            color: #fff;
            text-align: center;
            padding: 12px;
            font-size: .85rem;
            cursor: pointer;
        }

            .footer-back:hover {
                background: #485769;
            }

        .footer-mid {
            background: var(--amazon-mid);
            color: #fff;
            padding: 28px 20px;
        }

        .footer-mid-grid {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px,1fr));
            gap: 24px;
        }

        .footer-col h4 {
            font-size: .9rem;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .footer-col a {
            display: block;
            color: #ccc;
            text-decoration: none;
            font-size: .8rem;
            margin-bottom: 5px;
        }

            .footer-col a:hover {
                color: #fff;
            }

        .footer-bottom {
            background: var(--amazon-dark);
            color: #999;
            text-align: center;
            padding: 12px;
            font-size: .78rem;
        }

        /* ── PRODUCT CARD ────────────────────────────────── */
        .product-card {
            background: #fff;
            border-radius: 6px;
            overflow: hidden;
            transition: box-shadow .2s, transform .2s;
            cursor: pointer;
            border: 1px solid #e5e5e5;
        }

            .product-card:hover {
                box-shadow: 0 4px 20px rgba(0,0,0,.15);
                transform: translateY(-2px);
            }

            .product-card img {
                width: 100%;
                aspect-ratio: 1/1;
                object-fit: contain;
                padding: 12px;
                background: #fff;
            }

            .product-card .img-placeholder {
                width: 100%;
                aspect-ratio: 1/1;
                background: #f7f7f7;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 3rem;
                color: #ccc;
            }

            .product-card .card-body {
                padding: 10px 12px 14px;
            }

            .product-card .p-name {
                font-size: .88rem;
                font-weight: 600;
                line-height: 1.4;
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }

            .product-card .p-stars {
                color: var(--star);
                font-size: .8rem;
            }

            .product-card .p-price {
                font-size: 1.1rem;
                font-weight: 700;
                color: var(--red);
                margin-top: 4px;
            }

            .product-card .p-old {
                font-size: .78rem;
                color: var(--text-secondary);
                text-decoration: line-through;
            }

            .product-card .p-free {
                font-size: .78rem;
                color: var(--green);
                font-weight: 600;
            }

            .product-card .p-stock-low {
                font-size: .78rem;
                color: var(--red);
                font-weight: 600;
            }

        .btn-add-cart {
            width: 100%;
            background: var(--amazon-yellow);
            border: none;
            border-radius: 20px;
            padding: 7px;
            font-size: .82rem;
            font-weight: 700;
            cursor: pointer;
            margin-top: 8px;
            transition: background .2s;
            font-family: 'Cairo', sans-serif;
        }

            .btn-add-cart:hover {
                background: #e8a000;
            }

        /* ── BREADCRUMB ──────────────────────────────────── */
        .breadcrumb-bar {
            font-size: .8rem;
            color: var(--text-secondary);
            padding: 8px 0;
        }

            .breadcrumb-bar a {
                color: #007185;
                text-decoration: none;
            }

                .breadcrumb-bar a:hover {
                    text-decoration: underline;
                    color: #c7511f;
                }

            .breadcrumb-bar span {
                margin: 0 4px;
            }

        /* ── BADGES ──────────────────────────────────────── */
        .badge-prime {
            background: #00a8cc;
            color: #fff;
            font-size: .65rem;
            padding: 2px 6px;
            border-radius: 3px;
            font-weight: 700;
        }

        .badge-hot {
            background: #c60;
            color: #fff;
            font-size: .65rem;
            padding: 2px 6px;
            border-radius: 3px;
            font-weight: 700;
        }

        .badge-new {
            background: #067d62;
            color: #fff;
            font-size: .65rem;
            padding: 2px 6px;
            border-radius: 3px;
            font-weight: 700;
        }

        .badge-out {
            background: #ddd;
            color: #888;
            font-size: .65rem;
            padding: 2px 6px;
            border-radius: 3px;
        }

        /* ── BTN PRIMARY ─────────────────────────────────── */
        .btn-primary-shop {
            background: var(--amazon-yellow);
            border: 1px solid #c08800;
            border-radius: 20px;
            padding: 8px 18px;
            font-size: .88rem;
            font-weight: 700;
            cursor: pointer;
            font-family: 'Cairo', sans-serif;
            transition: background .2s;
            text-decoration: none;
            color: var(--text-primary);
            display: inline-block;
        }

            .btn-primary-shop:hover {
                background: #e8a000;
                color: var(--text-primary);
            }

        .btn-secondary-shop {
            background: #f0f2f2;
            border: 1px solid #d5d9d9;
            border-radius: 20px;
            padding: 8px 18px;
            font-size: .88rem;
            cursor: pointer;
            font-family: 'Cairo', sans-serif;
            transition: background .2s;
            text-decoration: none;
            color: var(--text-primary);
            display: inline-block;
        }

            .btn-secondary-shop:hover {
                background: #e3e6e6;
            }

        /* ── SIDEBAR FILTER ──────────────────────────────── */
        .filter-sidebar h3 {
            font-size: .88rem;
            font-weight: 700;
            padding: 10px 0 6px;
            border-bottom: 1px solid var(--border);
            margin-bottom: 8px;
        }

        .filter-sidebar .filter-section {
            margin-bottom: 16px;
        }

        .filter-sidebar .filter-title {
            font-size: .82rem;
            font-weight: 700;
            margin-bottom: 6px;
            color: var(--text-primary);
        }

        .filter-sidebar label {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: .8rem;
            color: #007185;
            cursor: pointer;
            margin-bottom: 4px;
        }

            .filter-sidebar label:hover {
                color: #c7511f;
            }

        .filter-sidebar input[type=range] {
            width: 100%;
            accent-color: var(--amazon-yellow);
        }

        /* ── ORDER STATUS ────────────────────────────────── */
        .status-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 12px;
            font-size: .75rem;
            font-weight: 700;
        }

        .status-pending {
            background: #fff3cd;
            color: #856404;
        }

        .status-processing {
            background: #cfe2ff;
            color: #0842a0;
        }

        .status-shipped {
            background: #d1ecf1;
            color: #0c5460;
        }

        .status-delivered {
            background: #d4edda;
            color: #155724;
        }

        .status-cancelled {
            background: #f8d7da;
            color: #721c24;
        }

        /* ── RESPONSIVE ──────────────────────────────────── */
        @@media (max-width: 768px) {
            .nav-search select

        {
            display: none;
        }

        .hide-mobile {
            display: none !important;
        }

        }
    </style>
</head>
<body>

    <!-- ═══ TOP NAVBAR ════════════════════════════════════════════ -->
    <header class="navbar-top">
        <a class="nav-logo" asp-controller="Home" asp-action="Index">
            Shop<span>Zone</span>
        </a>

        <!-- Delivery -->
        <div class="nav-btn hide-mobile" style="font-size:.72rem; line-height:1.4;">
            <small style="opacity:.7;">Deliver to</small>
            <strong style="font-size:.8rem;"><i class="bi bi-geo-alt-fill"></i> Egypt</strong>
        </div>

        <!-- Search -->
        <form class="nav-search" asp-controller="Category" asp-action="Index" method="get">
            <select name="categoryId" style="max-width:120px;">
                <option value="">All</option>
            </select>

            <input type="text"
                   name="q"
                   value="@ViewData["SearchTerm"]"
                   placeholder="Search products, brands and more..." />

            <button type="submit">
                <i class="bi bi-search"></i>
            </button>
        </form>

        <!-- Actions -->
        <div class="nav-actions">

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="nav-btn hide-mobile" style="position:relative;">
                    <small>Hello, @User.Identity.Name?.Split('@')[0]</small>
                    <strong>Account ▾</strong>
                </div>
            }
            else
            {
                <a class="nav-btn" asp-controller="Account" asp-action="Login">
                    <small>Hello, sign in</small>
                    <strong>Account &amp; Lists ▾</strong>
                </a>
            }

            <a class="nav-btn hide-mobile"
               asp-controller="Order"
               asp-action="Index">
                <small>Returns</small>
                <strong>&amp; Orders</strong>
            </a>

            <a class="nav-btn cart-btn"
               asp-controller="Cart"
               asp-action="Index">
                <i class="bi bi-cart3"></i>
                <span class="cart-count">0</span>
            </a>

        </div>
    </header>


    <!-- ═══ SUB NAVBAR ════════════════════════════════════════════ -->
    <nav class="navbar-sub">

        <a class="sub-link all"
           asp-controller="Home"
           asp-action="Index">
            <i class="bi bi-list"></i> All
        </a>

        <a class="sub-link"
           asp-controller="Category"
           asp-action="Index">
            Today's Deals
        </a>

        <a class="sub-link"
           asp-controller="Category"
           asp-action="Index">
            Categories
        </a>

        <a class="sub-link"
           asp-controller="Category"
           asp-action="Index">
            New Arrivals
        </a>

        <a class="sub-link"
           asp-controller="Category"
           asp-action="Index">
            Best Sellers
        </a>

        @if (User.IsInRole("Admin"))
        {
            <a class="sub-link"
               asp-area="Admin"
               asp-controller="Products"
               asp-action="Index"
               style="color:var(--amazon-orange);">

                <i class="bi bi-shield-lock"></i> Admin
            </a>
        }

    </nav>


    <!-- ═══ ALERTS ════════════════════════════════════════════════ -->
    @if (TempData["Success"] != null)
    {
        <div class="alert-bar success" id="alertSuccess">
            <i class="bi bi-check-circle-fill"></i>
            @TempData["Success"]

            <button class="close-btn"
                    onclick="this.parentElement.remove()">
                ×
            </button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert-bar danger" id="alertError">
            <i class="bi bi-exclamation-triangle-fill"></i>
            @TempData["Error"]

            <button class="close-btn"
                    onclick="this.parentElement.remove()">
                ×
            </button>
        </div>
    }


    <!-- ═══ CONTENT ═══════════════════════════════════════════════ -->
    @RenderBody()


    <!-- ═══ FOOTER ════════════════════════════════════════════════ -->
    <footer>

        <div class="footer-back"
             onclick="window.scrollTo({top:0,behavior:'smooth'})">
            Back to top
        </div>

        <div class="footer-mid">

            <div class="footer-mid-grid">

                <div class="footer-col">
                    <h4>Get to Know Us</h4>
                    <a href="#">About ShopZone</a>
                    <a href="#">Careers</a>
                    <a href="#">Press Releases</a>
                </div>

                <div class="footer-col">
                    <h4>Connect with Us</h4>
                    <a href="#"><i class="bi bi-facebook me-1"></i>Facebook</a>
                    <a href="#"><i class="bi bi-twitter me-1"></i>Twitter</a>
                    <a href="#"><i class="bi bi-instagram me-1"></i>Instagram</a>
                </div>

                <div class="footer-col">
                    <h4>Make Money with Us</h4>
                    <a href="#">Sell on ShopZone</a>
                    <a href="#">Become an Affiliate</a>
                    <a href="#">Advertise Your Products</a>
                </div>

                <div class="footer-col">
                    <h4>Let Us Help You</h4>
                    <a href="#">Your Account</a>

                    <a asp-controller="Order"
                       asp-action="Index">
                        Your Orders
                    </a>

                    <a href="#">Returns & Replacements</a>
                    <a href="#">Help</a>
                </div>

            </div>

        </div>

        <div class="footer-bottom">
            <strong style="color:#fff;">ShopZone</strong>
            &copy; @DateTime.Now.Year — All rights reserved.
        </div>

    </footer>


    <script>

        // Auto-dismiss alerts
        setTimeout(() => {

            ['alertSuccess','alertError'].forEach(id => {

                const el = document.getElementById(id);

                if (el) {
                    el.style.transition = 'opacity .5s';
                    el.style.opacity = '0';

                    setTimeout(() => el.remove(), 500);
                }

            });

        }, 4000);

    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
</html>
