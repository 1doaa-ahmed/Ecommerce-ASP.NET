@model Project_E_commerse.ViewModels.ProductListViewModel.ProductCreateVM

@{
    ViewData["Title"] = "Create Product";
}

<div class="page-wrap">
    
    <!-- Breadcrumb -->
    <div class="breadcrumb-bar">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span>›</span>
        <a asp-area="Admin" asp-controller="Products" asp-action="Index">Admin</a>
        <span>›</span>
        <a asp-controller="Category" asp-action="Index">Products</a>
        <span>›</span>
        Create
    </div>


    <div style="max-width:600px; margin:0 auto;">

        <div style="background:#fff; border:1px solid #ddd; border-radius:8px; padding:32px;">

            <!-- Header -->
            <div style="display:flex; align-items:center; gap:10px; margin-bottom:24px; padding-bottom:16px; border-bottom:2px solid var(--amazon-yellow);">
                <i class="bi bi-tag-fill" style="font-size:1.5rem; color:var(--amazon-yellow);"></i>
                <h2 style="font-size:1.3rem; font-weight:700; color:var(--text-primary); margin:0;">
                    Create New Product
                </h2>
            </div>

            <!-- Validation Summary -->
            <div asp-validation-summary="ModelOnly"
                 style="background:#fff0f0; border-left:4px solid #b12704; color:#b12704;
                        padding:10px 14px; border-radius:4px; font-size:.85rem; margin-bottom:20px;">
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div style="background:#f0fff4; border-left:4px solid #2e7d32; color:#2e7d32;
                            padding:10px 14px; border-radius:4px; font-size:.85rem; margin-bottom:20px;
                            display:flex; align-items:center; gap:8px;">
                    <i class="bi bi-check-circle-fill"></i>
                    <span>@TempData["SuccessMessage"]</span>
                </div>
            }
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <!-- Name Field -->
                <div style="margin-bottom:20px;">
                    <label asp-for="Name"
                           style="display:block; font-weight:700; font-size:.88rem; margin-bottom:6px; color:var(--text-primary);">
                        Product Name <span style="color:#b12704;">*</span>
                    </label>
                    <input asp-for="Name"
                           placeholder="e.g. Electronics, Clothing, Books..."
                           style="width:100%; padding:10px 12px; border:1px solid #ddd;
                                  border-radius:4px; font-size:.9rem; font-family:'Cairo',sans-serif;
                                  outline:none; transition:border-color .2s;"
                           onfocus="this.style.borderColor='var(--amazon-yellow)'"
                           onblur="this.style.borderColor='#ddd'" />
                    <span asp-validation-for="Name"
                          style="color:#b12704; font-size:.78rem; display:block; margin-top:4px;"></span>
                </div>
                 <!-- SKU Field -->
                <div style="margin-bottom:20px;">
                    <label asp-for="SKU"
                           style="display:block; font-weight:700; font-size:.88rem; margin-bottom:6px; color:var(--text-primary);">
                        SKU <span style="color:#b12704;">*</span>
                        <span style="font-weight:400; color:var(--text-secondary); font-size:.78rem;">(Stock Keeping Unit)</span>
                    </label>
                    <input asp-for="SKU"
                           placeholder="e.g. ELEC-001, SHOE-RED-42..."
                           style="width:100%; padding:10px 12px; border:1px solid #ddd;
                                  border-radius:4px; font-size:.9rem; font-family:'Cairo',sans-serif;
                                  outline:none; transition:border-color .2s;"
                           onfocus="this.style.borderColor='var(--amazon-yellow)'"
                           onblur="this.style.borderColor='#ddd'" />
                    <span asp-validation-for="SKU"
                          style="color:#b12704; font-size:.78rem; display:block; margin-top:4px;"></span>
                </div>

                <div style="display:flex; gap:16px; margin-bottom:20px;">

                    <!-- Price -->
                    <div style="flex:1;">
                        <label asp-for="Price"
                               style="display:block; font-weight:700; font-size:.88rem; margin-bottom:6px; color:var(--text-primary);">
                            Price <span style="color:#b12704;">*</span>
                        </label>
                        <div style="position:relative;">
                            <span style="position:absolute; left:10px; top:50%; transform:translateY(-50%);
                                         color:var(--text-secondary); font-size:.9rem; pointer-events:none;">$</span>
                            <input asp-for="Price"
                                   type="number" step="0.01" min="0"
                                   placeholder="0.00"
                                   style="width:100%; padding:10px 12px 10px 26px; border:1px solid #ddd;
                                          border-radius:4px; font-size:.9rem; font-family:'Cairo',sans-serif;
                                          outline:none; transition:border-color .2s;"
                                   onfocus="this.style.borderColor='var(--amazon-yellow)'"
                                   onblur="this.style.borderColor='#ddd'" />
                        </div>
                        <span asp-validation-for="Price"
                              style="color:#b12704; font-size:.78rem; display:block; margin-top:4px;"></span>
                    </div>

                    <div style="flex:1;">
                        <label asp-for="StockQuantity"
                               style="display:block; font-weight:700; font-size:.88rem; margin-bottom:6px; color:var(--text-primary);">
                            Stock Quantity <span style="color:#b12704;">*</span>
                        </label>
                        <input asp-for="StockQuantity"
                               type="number" min="0"
                               placeholder="0"
                               style="width:100%; padding:10px 12px; border:1px solid #ddd;
                                      border-radius:4px; font-size:.9rem; font-family:'Cairo',sans-serif;
                                      outline:none; transition:border-color .2s;"
                               onfocus="this.style.borderColor='var(--amazon-yellow)'"
                               onblur="this.style.borderColor='#ddd'" />
                        <span asp-validation-for="StockQuantity"
                              style="color:#b12704; font-size:.78rem; display:block; margin-top:4px;"></span>
                    </div>
                    </div>
                <!-- Category -->
                <div style="margin-bottom:20px;">
                    <label asp-for="CategoryId"
                           style="display:block; font-weight:700; font-size:.88rem; margin-bottom:6px; color:var(--text-primary);">
                        Category <span style="color:#b12704;">*</span>
                    </label>
                    <select asp-for="CategoryId"
                            asp-items="@(new SelectList(Model.Categories, "CategoryId", "Name"))"
                            style="width:100%; padding:10px 12px; border:1px solid #ddd;
                                   border-radius:4px; font-size:.9rem; font-family:'Cairo',sans-serif;
                                   outline:none; transition:border-color .2s; background:#fff;"
                            onfocus="this.style.borderColor='var(--amazon-yellow)'"
                            onblur="this.style.borderColor='#ddd'">
                        <option value="">-- Select Category --</option>
                    </select>
                    <span asp-validation-for="CategoryId"
                          style="color:#b12704; font-size:.78rem; display:block; margin-top:4px;"></span>
                </div>
                <!-- IsActive Toggle -->
                <div style="margin-bottom:28px; display:flex; align-items:center; gap:12px;
                             background:#f9f9f9; border:1px solid #ddd; border-radius:4px; padding:12px 16px;">
                    <input asp-for="IsActive"
                           type="checkbox"
                           style="width:18px; height:18px; accent-color:var(--amazon-yellow); cursor:pointer;" />
                    <div>
                        <label asp-for="IsActive"
                               style="font-weight:700; font-size:.88rem; color:var(--text-primary); cursor:pointer; margin:0;">
                            Active Product
                        </label>
                        <p style="margin:2px 0 0; font-size:.78rem; color:var(--text-secondary);">
                            Uncheck to hide this product from the store
                        </p>
                    </div>
                </div>
                <!-- Actions -->
                <div style="display:flex; gap:12px;">
                    <button type="submit" class="btn-primary-shop"
                            style="flex:1; text-align:center; border-radius:4px; padding:10px 0; font-size:.95rem;">
                        <i class="bi bi-plus-circle-fill me-1"></i> Create Product
                    </button>
                    <a asp-controller="Category" asp-action="Index"
                       class="btn-secondary-shop"
                       style="flex:1; text-align:center; border-radius:4px; padding:10px 0; font-size:.95rem;">
                        <i class="bi bi-x-circle me-1"></i> Cancel
                    </a>
                </div>

            </form>
        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
